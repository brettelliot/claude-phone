# Always required: used for text-to-speech, and for speech-to-text if STT_PROVIDER=openai
OPENAI_API_KEY=

# "claude" (Anthropic) or "gemini" (Google)
LLM_PROVIDER=claude

# Required only when LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-5

# Required only when LLM_PROVIDER=gemini. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest

# "wispr" (Wispr Flow REST API) or "openai" (Whisper, via OPENAI_API_KEY above)
STT_PROVIDER=wispr

# Required only when STT_PROVIDER=wispr. Get one at https://platform.wisprflow.ai/
WISPR_FLOW_API_KEY=
# WISPR_FLOW_LANGUAGE=en

# "keyboard" works on any machine (press Enter to pick up / hang up) and is the
# default while the phone's hook switch isn't wired up yet.
# "gpio" reads a real hook switch on the Raspberry Pi via gpiozero.
PHONE_TRIGGER=keyboard

# Only used when PHONE_TRIGGER=gpio
HOOK_GPIO_PIN=17

# Optional: override audio devices (see `python -m sounddevice` to list them)
# INPUT_DEVICE=
# OUTPUT_DEVICE=
